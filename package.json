{
  "name": "ibc-escrow-audit",
  "version": "1.0.0",
  "description": "IBC Escrow Audit Tool",
  "main": "dist/audit.js",
  "type": "module",
  "scripts": {
    "build": "npm run build:cli && npm run build:web",
    "build:cli": "tsc",
    "build:web": "tsc -p tsconfig.web.json",
    "dev": "tsc --watch",
    "start": "npm run build && node dist/audit.js",
    "quick": "npm run build && node dist/audit.js quick",
    "comprehensive": "npm run build && node dist/audit.js comprehensive",
    "lookup": "npm run build && node dist/audit.js lookup",
    "channel-info": "npm run build && node dist/audit.js channel-info",
    "update-chains": "npm run build && node dist/updateChains.js",
    "update-chains-force": "npm run build && node dist/updateChains.js -f",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "test": "node --import tsx --test \"src/**/*.test.ts\" \"web-src/**/*.test.ts\"",
    "test:watch": "node --import tsx --test --watch \"src/**/*.test.ts\" \"web-src/**/*.test.ts\"",
    "test:coverage": "node --import tsx --test --experimental-test-coverage \"src/**/*.test.ts\" \"web-src/**/*.test.ts\"",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.10.8",
    "@grpc/proto-loader": "^0.7.10",
    "adm-zip": "^0.5.16",
    "axios": "^1.6.8",
    "chalk": "^5.0.0",
    "dotenv": "^16.4.5",
    "inquirer": "^10.0.4",
    "lru-cache": "^10.2.0",
    "protobufjs": "^7.2.6",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@types/adm-zip": "^0.5.7",
    "@types/inquirer": "^9.0.7",
    "@types/node": "^20.11.30",
    "rimraf": "^5.0.5",
    "tsx": "^4.22.4",
    "typescript": "^5.4.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "MIT"
}
